---
import EpisodeList from '../components/EpisodeList.jsx';
import { getCollection } from 'astro:content';
import '../styles/global.css';
const episodes = await getCollection('episodes');
const staticEpisodes = episodes.map(e => ({ id: e.id, title: e.data.title, subtitle: e.data.subtitle ?? '' }));
---
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Event Storming by Example</title>
  </head>
  <body class="bg-gray-50 min-h-screen p-8">
    <h1 class="text-3xl font-bold mb-2">Event Storming by Example</h1>
    <p class="text-gray-500 mb-8">Okreść cel warsztatu, zbierz drużynę, rozmawiaj i modeluj</p>
    <EpisodeList initialEpisodes={staticEpisodes} client:load />
  </body>
</html>